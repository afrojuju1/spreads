flowchart TD
    A["Stock-led or option-led state changes"] --> B["Build RegimeSnapshot"]
    B --> C["Generate ranked StrategyIntents"]
    C --> D["Generate HorizonIntent"]
    D --> E["Arm symbol-side-style-strategy-horizon set"]
    E --> F["Pull targeted option data"]
    F --> G["Check data quality and quote budget"]
    G --> H["Build family-specific candidates"]
    H --> I["Apply hard eligibility gates"]
    I --> J["Compute discovery_score"]
    J --> K["Retain candidates in canonical store"]
    K --> L["Rank candidates inside each style profile"]
    L --> M["Apply strategy and side arbitration"]
    M --> N["Allocate portfolio risk across candidates"]
    N --> O["Expose allocated top slice as board view"]
    N --> P["Expose next retained slice as watchlist view"]
    N --> Q["Build ExecutionIntent for allocated candidates"]
    Q --> R["Compute execution_score"]
    R --> S{"Executable now?"}
    S -- "no" --> T["Remain retained, blocked, or deallocated with reason"]
    S -- "yes" --> U["Submit best executable candidate"]
    U --> V["Open position"]
    V --> W["Exit, reconcile, and record realized execution"]
    W --> X["Evaluate opportunity outcomes separately"]
    W --> Y["Evaluate execution quality separately"]
    X --> Z["Update bounded ranking calibration"]
    Y --> AA["Update bounded execution policy"]
